{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run mypy . 2>&1 | tail -5",
            "timeout": 60,
            "statusMessage": "Running mypy..."
          }
        ]
      }
    ]
  }
}
